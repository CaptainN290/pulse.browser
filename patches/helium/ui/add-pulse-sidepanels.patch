--- a/chrome/browser/ui/side_panel/side_panel_registry.cc
+++ b/chrome/browser/ui/side_panel/side_panel_registry.cc
@@
 #include "chrome/browser/ui/side_panel/side_panel_registry.h"
@@
 void RegisterSidePanelEntries(SidePanelRegistry* registry) {
   // Existing registrations...

+  // pulse. side panels: Discord and Spotify
  registry->RegisterEntry(SidePanelEntry::CreateWebView(
    SidePanelEntryId::kPulseDiscord,
    base::ASCIIToUTF16("Discord"),
    GURL("chrome://side-panel/pulse_discord/app.html"),
    SidePanelEntry::PanelType::kToolbar));

  registry->RegisterEntry(SidePanelEntry::CreateWebView(
    SidePanelEntryId::kPulseSpotify,
    base::ASCIIToUTF16("Spotify"),
    GURL("chrome://side-panel/pulse_spotify/app.html"),
    SidePanelEntry::PanelType::kToolbar));

 }
