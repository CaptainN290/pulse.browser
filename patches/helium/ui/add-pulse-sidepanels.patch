--- a/chrome/browser/resources/side_panel/pulse_discord/app.html.ts
+++ b/chrome/browser/resources/side_panel/pulse_discord/app.html.ts
@@
+<template>
+  <div id="pulse-discord-root"></div>
+</template>
+
+<script>
+  // Load the shared panel code and open Discord in the panel iframe
+  (function(){
+    const script = document.createElement('script');
+    script.src = '../../pulse_panels.js';
+    script.onload = () => {
+      // Ensure global API exists and then set the iframe src directly to the Discord app.
+      if (window.openPulseDiscordPanel) {
+        window.openPulseDiscordPanel();
+      } else if (window.togglePulsePanel) {
+        window.togglePulsePanel('discord');
+      }
+    };
+    document.head.appendChild(script);
+  })();
+</script>

